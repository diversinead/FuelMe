# Copy to .env and fill in. .env is gitignored.

# OpenAI — required for AI plan / grocery / feedback generation.
OPENAI_API_KEY=sk-...

# Admin page (/admin) — password to edit nutrition rules locally (Phase 7).
# Local-dev only: admin edits write to the filesystem, which is read-only on
# Vercel. Choose a strong value.
ADMIN_PASSWORD=choose-a-strong-password
